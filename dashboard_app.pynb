{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOS9w8l3D8JYGSLxYzk4GOw"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["!pip install dash plotly pandas"],"metadata":{"id":"YEQ5cjVOCNfF","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1774343532395,"user_tz":-330,"elapsed":5138,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}},"outputId":"d190c66e-4175-41ce-f395-6941815c33a4"},"execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: dash in /usr/local/lib/python3.12/dist-packages (4.1.0)\n","Requirement already satisfied: plotly in /usr/local/lib/python3.12/dist-packages (5.24.1)\n","Requirement already satisfied: pandas in /usr/local/lib/python3.12/dist-packages (2.2.2)\n","Requirement already satisfied: Flask<3.2,>=1.0.4 in /usr/local/lib/python3.12/dist-packages (from dash) (3.1.3)\n","Requirement already satisfied: Werkzeug<3.2 in /usr/local/lib/python3.12/dist-packages (from dash) (3.1.6)\n","Requirement already satisfied: importlib-metadata in /usr/local/lib/python3.12/dist-packages (from dash) (8.7.1)\n","Requirement already satisfied: typing_extensions>=4.1.1 in /usr/local/lib/python3.12/dist-packages (from dash) (4.15.0)\n","Requirement already satisfied: requests in /usr/local/lib/python3.12/dist-packages (from dash) (2.32.4)\n","Requirement already satisfied: retrying in /usr/local/lib/python3.12/dist-packages (from dash) (1.4.2)\n","Requirement already satisfied: nest-asyncio in /usr/local/lib/python3.12/dist-packages (from dash) (1.6.0)\n","Requirement already satisfied: setuptools in /usr/local/lib/python3.12/dist-packages (from dash) (75.2.0)\n","Requirement already satisfied: tenacity>=6.2.0 in /usr/local/lib/python3.12/dist-packages (from plotly) (9.1.4)\n","Requirement already satisfied: packaging in /usr/local/lib/python3.12/dist-packages (from plotly) (26.0)\n","Requirement already satisfied: numpy>=1.26.0 in /usr/local/lib/python3.12/dist-packages (from pandas) (2.0.2)\n","Requirement already satisfied: python-dateutil>=2.8.2 in /usr/local/lib/python3.12/dist-packages (from pandas) (2.9.0.post0)\n","Requirement already satisfied: pytz>=2020.1 in /usr/local/lib/python3.12/dist-packages (from pandas) (2025.2)\n","Requirement already satisfied: tzdata>=2022.7 in /usr/local/lib/python3.12/dist-packages (from pandas) (2025.3)\n","Requirement already satisfied: blinker>=1.9.0 in /usr/local/lib/python3.12/dist-packages (from Flask<3.2,>=1.0.4->dash) (1.9.0)\n","Requirement already satisfied: click>=8.1.3 in /usr/local/lib/python3.12/dist-packages (from Flask<3.2,>=1.0.4->dash) (8.3.1)\n","Requirement already satisfied: itsdangerous>=2.2.0 in /usr/local/lib/python3.12/dist-packages (from Flask<3.2,>=1.0.4->dash) (2.2.0)\n","Requirement already satisfied: jinja2>=3.1.2 in /usr/local/lib/python3.12/dist-packages (from Flask<3.2,>=1.0.4->dash) (3.1.6)\n","Requirement already satisfied: markupsafe>=2.1.1 in /usr/local/lib/python3.12/dist-packages (from Flask<3.2,>=1.0.4->dash) (3.0.3)\n","Requirement already satisfied: six>=1.5 in /usr/local/lib/python3.12/dist-packages (from python-dateutil>=2.8.2->pandas) (1.17.0)\n","Requirement already satisfied: zipp>=3.20 in /usr/local/lib/python3.12/dist-packages (from importlib-metadata->dash) (3.23.0)\n","Requirement already satisfied: charset_normalizer<4,>=2 in /usr/local/lib/python3.12/dist-packages (from requests->dash) (3.4.6)\n","Requirement already satisfied: idna<4,>=2.5 in /usr/local/lib/python3.12/dist-packages (from requests->dash) (3.11)\n","Requirement already satisfied: urllib3<3,>=1.21.1 in /usr/local/lib/python3.12/dist-packages (from requests->dash) (2.5.0)\n","Requirement already satisfied: certifi>=2017.4.17 in /usr/local/lib/python3.12/dist-packages (from requests->dash) (2026.2.25)\n"]}]},{"cell_type":"code","execution_count":16,"metadata":{"id":"stnINz8XBkJO","executionInfo":{"status":"ok","timestamp":1774343532413,"user_tz":-330,"elapsed":12,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"outputs":[],"source":["import pandas as pd\n","import numpy as np\n","import plotly.express as px\n","import plotly.graph_objects as go\n","from plotly.subplots import make_subplots\n","import dash\n","from dash import dcc, html, Input, Output\n","import warnings\n","warnings.filterwarnings('ignore')"]},{"cell_type":"code","source":["#load and prepare data\n","df = pd.read_csv('/content/ecommerce_data.csv')\n","df['order_date']  = pd.to_datetime(df['order_date'])\n","df['month_name']  = df['order_date'].dt.strftime('%b %Y')\n","df['month_num']   = df['order_date'].dt.month\n","df['order_month'] = df['order_date'].dt.to_period('M')"],"metadata":{"id":"1yXOusrkCkgL","executionInfo":{"status":"ok","timestamp":1774343532444,"user_tz":-330,"elapsed":17,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":17,"outputs":[]},{"cell_type":"code","source":["# KPIs\n","total_revenue    = df['revenue'].sum()\n","total_orders     = df['order_id'].nunique()\n","total_customers  = df['customer_id'].nunique()\n","aov              = total_revenue / total_orders"],"metadata":{"id":"3HrPrz-OC2r5","executionInfo":{"status":"ok","timestamp":1774343532465,"user_tz":-330,"elapsed":7,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":18,"outputs":[]},{"cell_type":"code","source":["# Monthly revenue\n","monthly = df.groupby('month_num').agg(revenue=('revenue','sum'), orders=('order_id','count')).reset_index()\n","month_labels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\n","monthly['month_label'] = monthly['month_num'].apply(lambda x: month_labels[x-1])\n","\n","# Category revenue\n","cat_rev = df.groupby('category')['revenue'].sum().reset_index()\n","\n","# Region revenue\n","reg_rev = df.groupby('region')['revenue'].sum().reset_index().sort_values('revenue', ascending=False)\n","\n","# Top products\n","top_prod = df.groupby('product')['revenue'].sum().reset_index().sort_values('revenue', ascending=False).head(10)\n"],"metadata":{"id":"eXgkLWrRC5_6","executionInfo":{"status":"ok","timestamp":1774343532514,"user_tz":-330,"elapsed":35,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":19,"outputs":[]},{"cell_type":"code","source":["# RFM\n","reference_date = df['order_date'].max() + pd.Timedelta(days=1)\n","rfm = df.groupby('customer_id').agg(\n","    Recency   = ('order_date',  lambda x: (reference_date - x.max()).days),\n","    Frequency = ('order_id',    'count'),\n","    Monetary  = ('revenue',     'sum')\n",").reset_index()\n","rfm['R_Score'] = pd.qcut(rfm['Recency'], q=4, labels=[4,3,2,1], duplicates='drop')\n","rfm['F_Score'] = pd.qcut(rfm['Frequency'].rank(method='first'), q=4, labels=[1,2,3,4])\n","rfm['M_Score'] = pd.qcut(rfm['Monetary'], q=4, labels=[1,2,3,4], duplicates='drop')\n","rfm['Total_Score'] = rfm[['R_Score','F_Score','M_Score']].astype(int).sum(axis=1)\n","def segment_customer(score):\n","    if score >= 11:  return 'Champions'\n","    elif score >= 9: return 'Loyal'\n","    elif score >= 7: return 'Potential'\n","    elif score >= 5: return 'At Risk'\n","    else:            return 'Lost'\n","rfm['Segment'] = rfm['Total_Score'].apply(segment_customer)\n","\n","seg_counts = rfm['Segment'].value_counts().reset_index()\n","seg_counts.columns = ['Segment','Count']\n"],"metadata":{"id":"Jus6ZREDC-dF","executionInfo":{"status":"ok","timestamp":1774343532535,"user_tz":-330,"elapsed":5,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":20,"outputs":[]},{"cell_type":"code","source":["# ─── Dash App ────────────────────────────────────────────────\n","app = dash.Dash(__name__)\n","app.title = \"Deep-Dive Analysis Dashboard\"\n","\n","COLORS = {\n","    'bg'       : '#0f172a',\n","    'card'     : '#1e293b',\n","    'accent1'  : '#38bdf8',\n","    'accent2'  : '#818cf8',\n","    'accent3'  : '#34d399',\n","    'accent4'  : '#fb923c',\n","    'text'     : '#f1f5f9',\n","    'subtext'  : '#94a3b8',\n","}\n","\n","def kpi_card(title, value, color):\n","    return html.Div([\n","        html.P(title, style={'color': COLORS['subtext'], 'fontSize':'13px', 'margin':'0'}),\n","        html.H3(value, style={'color': color, 'margin':'4px 0 0 0', 'fontSize':'24px'}),\n","    ], style={\n","        'background': COLORS['card'],\n","        'borderRadius': '10px',\n","         'padding': '16px 20px',\n","        'flex': '1',\n","        'minWidth': '160px',\n","        'borderLeft': f'4px solid {color}'\n","    })\n","\n","app.layout = html.Div(style={'background': COLORS['bg'], 'minHeight': '100vh', 'fontFamily': 'Segoe UI, sans-serif', 'padding': '24px'}, children=[\n"," # Header\n","    html.Div([\n","        html.H1('Deep-Dive Analysis & Interactive Dashboard',\n","                style={'color': COLORS['text'], 'margin': '0', 'fontSize': '26px'}),\n","        html.P('ApexPlanet Internship — Task 3 | E-Commerce Sales Analysis 2024',\n","               style={'color': COLORS['subtext'], 'margin': '4px 0 0 0'}),\n","    ], style={'marginBottom': '24px'}),\n"," # KPI Row\n","    html.Div([\n","        kpi_card('Total Revenue',   f'₹{total_revenue:,.0f}',  COLORS['accent3']),\n","        kpi_card('Total Orders',    f'{total_orders}',          COLORS['accent1']),\n","        kpi_card('Customers',       f'{total_customers}',       COLORS['accent2']),\n","        kpi_card('Avg Order Value', f'₹{aov:,.0f}',            COLORS['accent4']),\n","    ], style={'display': 'flex', 'gap': '16px', 'marginBottom': '24px', 'flexWrap': 'wrap'}),\n","\n","    # Filter\n","    html.Div([\n","        html.Label('Filter by Region:', style={'color': COLORS['subtext'], 'marginRight': '10px'}),\n","        dcc.Dropdown(\n","            id='region-filter',\n","            options=[{'label': 'All Regions', 'value': 'ALL'}] +\n","                    [{'label': r, 'value': r} for r in df['region'].unique()],\n","            value='ALL',\n","            style={'width': '220px', 'color': '#000'},\n","            clearable=False\n","        )\n","    ], style={'display': 'flex', 'alignItems': 'center', 'marginBottom': '20px'}),\n","  # Row 1: Monthly Revenue + Category Pie\n","    html.Div([\n","        html.Div([dcc.Graph(id='monthly-revenue')],\n","                 style={'flex': '2', 'background': COLORS['card'], 'borderRadius': '10px', 'padding': '10px'}),\n","        html.Div([dcc.Graph(id='category-pie')],\n","                 style={'flex': '1', 'background': COLORS['card'], 'borderRadius': '10px', 'padding': '10px'}),\n","    ], style={'display': 'flex', 'gap': '16px', 'marginBottom': '16px'}),\n","\n","    # Row 2: Top Products + Region Bar\n","    html.Div([\n","        html.Div([dcc.Graph(id='top-products')],\n","                 style={'flex': '1', 'background': COLORS['card'], 'borderRadius': '10px', 'padding': '10px'}),\n","        html.Div([dcc.Graph(id='region-bar')],\n","                 style={'flex': '1', 'background': COLORS['card'], 'borderRadius': '10px', 'padding': '10px'}),\n","    ], style={'display': 'flex', 'gap': '16px', 'marginBottom': '16px'}),\n","  # Row 3: RFM Segment + Scatter\n","    html.Div([\n","        html.Div([dcc.Graph(id='rfm-segment')],\n","                 style={'flex': '1', 'background': COLORS['card'], 'borderRadius': '10px', 'padding': '10px'}),\n","        html.Div([dcc.Graph(id='rfm-scatter')],\n","                 style={'flex': '1', 'background': COLORS['card'], 'borderRadius': '10px', 'padding': '10px'}),\n","    ], style={'display': 'flex', 'gap': '16px'}),\n","\n","])\n"],"metadata":{"id":"WvgbC5rdDCNK","executionInfo":{"status":"ok","timestamp":1774343532619,"user_tz":-330,"elapsed":71,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":21,"outputs":[]},{"cell_type":"code","source":["CHART_LAYOUT = dict(\n","    paper_bgcolor='rgba(0,0,0,0)',\n","    plot_bgcolor='rgba(0,0,0,0)',\n","    font=dict(color=COLORS['text']),\n","    margin=dict(l=30, r=20, t=40, b=40),\n",")"],"metadata":{"id":"ai0UhMb2DlZK","executionInfo":{"status":"ok","timestamp":1774343532650,"user_tz":-330,"elapsed":4,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":22,"outputs":[]},{"cell_type":"code","source":["@app.callback(\n","    Output('monthly-revenue', 'figure'),\n","    Output('category-pie',    'figure'),\n","    Output('top-products',    'figure'),\n","    Output('region-bar',      'figure'),\n","    Output('rfm-segment',     'figure'),\n","    Output('rfm-scatter',     'figure'),\n","    Input('region-filter',    'value'),\n",")\n","def update_charts(region):\n","    filtered = df if region == 'ALL' else df[df['region'] == region]\n","\n","    m = filtered.groupby('month_num')['revenue'].sum().reset_index()\n","    m['month_label'] = m['month_num'].apply(lambda x: month_labels[x-1])\n","\n","    # Monthly Revenue\n","    fig1 = px.bar(m, x='month_label', y='revenue', title='Monthly Revenue Trend',\n","                  color='revenue', color_continuous_scale='Blues')\n","    fig1.update_layout(**CHART_LAYOUT, title_font_size=14)\n","    fig1.update_coloraxes(showscale=False)\n","\n","    # Category Pie\n","    c = filtered.groupby('category')['revenue'].sum().reset_index()\n","    fig2 = px.pie(c, values='revenue', names='category', title='🏷️ Revenue by Category',\n","                  color_discrete_sequence=px.colors.qualitative.Set3, hole=0.4)\n","    fig2.update_layout(**CHART_LAYOUT, title_font_size=14)\n","\n","    # Top Products\n","    tp = filtered.groupby('product')['revenue'].sum().reset_index().sort_values('revenue', ascending=False).head(10)\n","    fig3 = px.bar(tp, x='product', y='revenue', title='🏆 Top 10 Products',\n","                  color='revenue', color_continuous_scale='Viridis')\n","    fig3.update_layout(**CHART_LAYOUT, title_font_size=14, xaxis_tickangle=-35)\n","    fig3.update_coloraxes(showscale=False)\n","\n","    # Region\n","    rr = filtered.groupby('region')['revenue'].sum().reset_index()\n","    fig4 = px.bar(rr, x='region', y='revenue', title='Revenue by Region',\n","                  color='region', color_discrete_sequence=px.colors.qualitative.Pastel)\n","    fig4.update_layout(**CHART_LAYOUT, title_font_size=14, showlegend=False)\n","\n","    # RFM Segment (global, not filtered)\n","    fig5 = px.bar(seg_counts, x='Segment', y='Count', title='Customer Segments (RFM)',\n","                  color='Segment', color_discrete_sequence=px.colors.qualitative.Set2)\n","    fig5.update_layout(**CHART_LAYOUT, title_font_size=14, showlegend=False)\n","\n","    # RFM Scatter\n","    fig6 = px.scatter(rfm, x='Recency', y='Monetary', color='Segment', size='Frequency',\n","                      title='Recency vs Revenue by Segment',\n","                      color_discrete_sequence=px.colors.qualitative.Set1,\n","                      hover_data=['customer_id','Frequency'])\n","    fig6.update_layout(**CHART_LAYOUT, title_font_size=14)\n","\n","    return fig1, fig2, fig3, fig4, fig5, fig6\n","\n","\n","if __name__ == '__main__':\n","    print(\"Dashboard running at: http://127.0.0.1:8050\")\n","    app.run(debug=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"uOMLjPmhDpRL","outputId":"9af8a5de-0cdb-4973-cf31-045690a93fcf","executionInfo":{"status":"ok","timestamp":1774343527219,"user_tz":-330,"elapsed":664898,"user":{"displayName":"VIVEK YADAV","userId":"05806225440046916318"}}},"execution_count":14,"outputs":[{"metadata":{"tags":null},"name":"stdout","output_type":"stream","text":["🚀 Dashboard running at: http://127.0.0.1:8050\n","Dash is running on http://127.0.0.1:8050/\n","\n"]},{"metadata":{"tags":null},"name":"stderr","output_type":"stream","text":["INFO:dash.dash:Dash is running on http://127.0.0.1:8050/\n","\n"]},{"metadata":{"tags":null},"name":"stdout","output_type":"stream","text":[" * Serving Flask app '__main__'\n"," * Debug mode: on\n"]}]}]}